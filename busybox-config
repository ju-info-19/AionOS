# Busybox configuration for AionOS – minimal static build
CONFIG_STATIC=y
CONFIG_NOMMU=n
CONFIG_CROSS_COMPILER_PREFIX=""
CONFIG_EXTRA_CFLAGS="-Os"
CONFIG_EXTRA_LDFLAGS="-static"

# Applets required
CONFIG_INIT=y
CONFIG_SH_IS_ASH=y
CONFIG_ASH=y
CONFIG_CAT=y
CONFIG_ECHO=y
CONFIG_LS=y
CONFIG_PS=y
CONFIG_KILL=y
CONFIG_MOUNT=y
CONFIG_UMOUNT=y
CONFIG_HOSTNAME=y
CONFIG_MKNOD=y
CONFIG_CHROOT=y

# Network (for API)
CONFIG_NC=y
CONFIG_WGET=y

# Tools for debugging
CONFIG_TOP=y
CONFIG_FREE=y